{
    "name": "streamdown-solidjs",
    "version": "0.0.0",
    "description": "Streamdown components for Solid.js",
    "license": "MIT",
    "author": "coolRoger",
    "contributors": [],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/coolRoger/streamdown-solid.git"
    },
    "homepage": "https://github.com/coolRoger/streamdown-solid#readme",
    "bugs": {
        "url": "https://github.com/coolRoger/streamdown-solid/issues"
    },
    "files": [
        "dist"
    ],
    "private": false,
    "sideEffects": false,
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "browser": {},
    "exports": {
        "solid": {
            "development": "./dist/dev.jsx",
            "import": "./dist/index.jsx"
        },
        "development": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/dev.js"
            }
        },
        "import": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "typesVersions": {},
    "scripts": {
        "dev": "vite serve dev",
        "build": "tsup",
        "test": "concurrently pnpm:test:*",
        "test:client": "vitest",
        "test:ssr": "pnpm run test:client --mode ssr",
        "prepublishOnly": "pnpm build",
        "format": "biome format --write",
        "check": "biome check",
        "lint:types": "tsc --noEmit",
        "update-deps": "pnpm up -Li"
    },
    "peerDependencies": {
        "solid-js": "^1.9.12"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.14",
        "@types/node": "^20.12.12",
        "concurrently": "^8.2.2",
        "esbuild": "^0.21.3",
        "esbuild-plugin-solid": "^0.6.0",
        "jsdom": "^24.0.0",
        "solid-js": "^1.8.17",
        "tsup": "^8.0.2",
        "tsup-preset-solid": "^2.2.0",
        "typescript": "^5.4.5",
        "vite": "^5.2.11",
        "vite-plugin-solid": "^2.10.2",
        "vitest": "^1.6.0"
    },
    "keywords": [
        "solid"
    ],
    "packageManager": "pnpm@9.1.1",
    "engines": {
        "node": ">=18",
        "pnpm": ">=9.0.0"
    },
    "dependencies": {
        "@types/hast": "^3.0.4",
        "@types/mdast": "^4.0.4",
        "@types/unist": "^3.0.3",
        "hast-util-to-jsx-runtime": "^2.3.6",
        "html-url-attributes": "^3.0.1",
        "marked": "^18.0.3",
        "mermaid": "^11.14.0",
        "rehype": "^13.0.2",
        "rehype-harden": "^1.1.8",
        "rehype-raw": "^7.0.0",
        "rehype-sanitize": "^6.0.0",
        "remark-gfm": "^4.0.1",
        "remark-parse": "^11.0.0",
        "remark-rehype": "^11.1.2",
        "shiki": "^4.0.2",
        "unified": "^11.0.5",
        "unist-util-visit": "^5.1.0",
        "unist-util-visit-parents": "^6.0.2"
    }
}
